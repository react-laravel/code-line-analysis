{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Code Line Analysis",
  "version": "0.1.0",
  "identifier": "com.sam.codelineanalysis",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:ui"
  },
  "app": {
    "windows": [
      {
        "title": "Code Line Analysis",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Local code line analysis for repositories",
    "longDescription": "Scan local repositories, count lines of code, browse tags, duplicates, Git metadata, and Laravel/Next route analysis.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
