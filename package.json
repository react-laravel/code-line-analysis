{
  "name": "code-line-analysis",
  "version": "0.1.0",
  "description": "Electron app for code line counting, baseline diff, tags, and code viewing/editing",
  "main": "dist/main/index.js",
  "author": "sam",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json -w",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build:web": "vite build",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "preview:web": "vite preview --host 0.0.0.0 --port 4173",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:signed": "npm run build && electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "better-sqlite3": "^12.9.0",
    "echarts": "^5.6.0",
    "fast-glob": "^3.3.2",
    "ignore": "^6.0.2",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.52.0",
    "p-limit": "^6.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.27.0",
    "simple-git": "^3.27.0",
    "xxhash-wasm": "^1.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "41.3.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.sam.codelineanalysis",
    "productName": "Code Line Analysis",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
